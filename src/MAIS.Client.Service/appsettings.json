{
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz}] [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/MAIS.Client-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5002"
      }
    }
  },
  "Mais": {
    "LaunchSidebarOnStart": false,
    "BuildConfiguration": "Release"
  },
  "Client": {
    "ServerUrl": "http://localhost:5000",
    "UserRole": "Support",
    "LaunchSidebarOnStart": true,
    "SidebarExecutablePath": "C:\\Program Files\\MAIS\\MAIS.Sidebar.exe",
    "HealthReportIntervalSeconds": 60,
    "PolicyRefreshIntervalSeconds": 300
  },
  "Modules": {
    "CrimsAddinHealth": {
      "CrimsAddinsFolder": "C:\\CharlesRiver\\23R3\\Client\\AddIns",
      "AssetTag": "",
      "CrimsUserId": "",
      "ScanSchedule": "0 8 * * *",
      "CrimsCloseTimeoutSeconds": 300,
      "ValidationRetryCount": 3,
      "UpdateResponseTimeoutSeconds": 120,
      "CrimsStatusCheckIntervalSeconds": 5
    },
    "CrimsSeverity": {
      "HostType": "Client",
      "DataEndpointUrl": "http://boswidad01:8080/api/dashboard/filterseverity",
      "SourceApplicationUrl": "http://boswidad01:8080",
      "PollingIntervalSeconds": 10,
      "SpikeWindowCycles": 3,
      "SpikeCriticalDeltaThreshold": 50,
      "CooldownSeconds": 120,
      "RequestTimeoutSeconds": 5
    },
    "IdaLogIngestion": {
      "HostType": "Client",
      "AssetTag": "",
      "ServerApiUrl": "http://localhost:5000",
      "SpoolPath": "C:\\ProgramData\\MAIS\\IdaLogIngestion\\Spool",
      "LocalRegistryCachePath": "C:\\ProgramData\\MAIS\\IdaLogIngestion\\RegistryCache",
      "Sources": [
        {
          "AppId": "MAIS.Client.Service",
          "DisplayName": "MAIS Client Service",
          "LogFolderPath": "C:\\Program Files\\MAIS\\logs",
          "ActiveFileName": "MAIS.Client-.txt",
          "MultilineStartPattern": "^\\[\\d{4}-\\d{2}-\\d{2}",
          "CompatibilityAppName": "mais_client"
        }
      ]
    }
  }
}
