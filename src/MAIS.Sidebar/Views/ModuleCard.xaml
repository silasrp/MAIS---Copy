<UserControl x:Class="MAIS.Sidebar.Views.ModuleCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MAIS.Sidebar.ViewModels"
             xmlns:conv="clr-namespace:MAIS.Sidebar.Converters"
             xmlns:models="clr-namespace:MAIS.Core.Models;assembly=MAIS.Core">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:StatusToBrushConverter x:Key="StatusToBrush"/>
            <conv:StatusToPulseVisibilityConverter x:Key="StatusToPulse"/>
            <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
            <conv:NullOrEmptyToCollapsedConverter x:Key="NullToCollapsed"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- Card shell -->
    <Border Style="{StaticResource ModuleCard}">
        <Border.Triggers>
            <EventTrigger RoutedEvent="Border.MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                        To="#1C2A47" Duration="0:0:0.15"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="Border.MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                        To="#16213E" Duration="0:0:0.15"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- name + status dot -->
                <RowDefinition Height="Auto"/>   <!-- description -->
                <RowDefinition Height="Auto"/>   <!-- status message -->
                <RowDefinition Height="Auto"/>   <!-- action buttons -->
            </Grid.RowDefinitions>

            <!-- ── Row 0: name + status ── -->
            <Grid Grid.Row="0" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- status dot -->
                    <ColumnDefinition Width="*"/>     <!-- name -->
                    <ColumnDefinition Width="Auto"/>  <!-- type badge -->
                </Grid.ColumnDefinitions>

                <!-- Status dot with pulse for transient states -->
                <Grid Grid.Column="0" Width="14" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Ellipse Style="{StaticResource StatusDot}"
                             Fill="{Binding Status, Converter={StaticResource StatusToBrush}}"/>
                    <!-- Pulse ring for Starting/Stopping -->
                    <Ellipse Width="14" Height="14" VerticalAlignment="Center"
                             Stroke="{Binding Status, Converter={StaticResource StatusToBrush}}"
                             StrokeThickness="1" Fill="Transparent"
                             Visibility="{Binding Status, Converter={StaticResource StatusToPulse}}">
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Ellipse.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="1" To="0" Duration="0:0:1"
                                                         AutoReverse="False"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                </Grid>

                <!-- Module name -->
                <TextBlock Grid.Column="1"
                           Text="{Binding DisplayName}"
                           Style="{StaticResource TextHeading}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>

                <!-- Module type badge -->
                <Border Grid.Column="2" CornerRadius="3" Padding="5,2" Margin="6,0,0,0"
                        Background="#1E2D4A" VerticalAlignment="Center">
                    <TextBlock Text="{Binding TypeLabel}"
                               Style="{StaticResource TextMuted}"
                               FontSize="9"/>
                </Border>
            </Grid>

            <!-- ── Row 1: description ── -->
            <TextBlock Grid.Row="1"
                       Text="{Binding Description}"
                       Style="{StaticResource TextSecondary}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,4"/>

            <!-- ── Row 2: status label + optional message ── -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8"
                        Visibility="{Binding StatusMessage, Converter={StaticResource NullToCollapsed}}">
                <TextBlock Text="{Binding StatusLabel}"
                           Style="{StaticResource TextMuted}"
                           FontSize="10"/>
                <TextBlock Text=" — " Style="{StaticResource TextMuted}" FontSize="10"/>
                <TextBlock Text="{Binding StatusMessage}"
                           Style="{StaticResource TextMuted}"
                           FontSize="10"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="160"
                           ToolTip="{Binding StatusMessage}"/>
            </StackPanel>

            <!-- Status label only (when no message) -->
            <TextBlock Grid.Row="2"
                       Text="{Binding StatusLabel}"
                       Style="{StaticResource TextMuted}"
                       FontSize="10"
                       Margin="0,0,0,8"
                       Visibility="{Binding StatusMessage, Converter={StaticResource NullToCollapsed}}"/>

            <!-- ── Row 3: action buttons ── -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Open / Launch -->
                <Button Grid.Column="0"
                        Content="Open"
                        Style="{StaticResource AccentButton}"
                        Command="{Binding LaunchCommand}"
                        Visibility="{Binding CanLaunch, Converter={StaticResource BoolToVis}}"
                        HorizontalAlignment="Left"
                        Height="24"/>

                <!-- Start -->
                <Button Grid.Column="1"
                        Content="Start"
                        Style="{StaticResource GhostButton}"
                        Command="{Binding StartCommand}"
                        Visibility="{Binding CanStart, Converter={StaticResource BoolToVis}}"
                        Height="24"
                        Margin="0,0,4,0"/>

                <!-- Stop -->
                <Button Grid.Column="2"
                        Content="Stop"
                        Style="{StaticResource DangerButton}"
                        Command="{Binding StopCommand}"
                        Visibility="{Binding CanStop, Converter={StaticResource BoolToVis}}"
                        Height="24"/>
            </Grid>

        </Grid>
    </Border>
</UserControl>
