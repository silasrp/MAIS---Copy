<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Background surfaces ── -->
    <Color x:Key="ColorBackground">#1A1A2E</Color>
    <Color x:Key="ColorSurface">#16213E</Color>
    <Color x:Key="ColorSurfaceElevated">#0F3460</Color>
    <Color x:Key="ColorSurfaceHover">#1E2D4A</Color>
    <Color x:Key="ColorBorder">#2A3A5C</Color>
    <Color x:Key="ColorBorderSubtle">#1E2D4A</Color>

    <!-- ── Text ── -->
    <Color x:Key="ColorTextPrimary">#E8EAF0</Color>
    <Color x:Key="ColorTextSecondary">#8B95B0</Color>
    <Color x:Key="ColorTextMuted">#4A5568</Color>
    <Color x:Key="ColorTextAccent">#6C8EFF</Color>

    <!-- ── Status indicators ── -->
    <Color x:Key="ColorStatusRunning">#34D399</Color>
    <Color x:Key="ColorStatusDegraded">#FBBF24</Color>
    <Color x:Key="ColorStatusFaulted">#F87171</Color>
    <Color x:Key="ColorStatusStopped">#4A5568</Color>
    <Color x:Key="ColorStatusStarting">#60A5FA</Color>
    <Color x:Key="ColorStatusUnknown">#6B7280</Color>

    <!-- ── Actions ── -->
    <Color x:Key="ColorAccent">#6C8EFF</Color>
    <Color x:Key="ColorAccentHover">#8BA3FF</Color>
    <Color x:Key="ColorDanger">#F87171</Color>
    <Color x:Key="ColorDangerHover">#FCA5A5</Color>
    <Color x:Key="ColorSuccess">#34D399</Color>

    <!-- ── Connection status ── -->
    <Color x:Key="ColorConnected">#34D399</Color>
    <Color x:Key="ColorDisconnected">#F87171</Color>
    <Color x:Key="ColorConnecting">#FBBF24</Color>

    <!-- ── Brushes (derived from colors above) ── -->
    <SolidColorBrush x:Key="BrushBackground"       Color="{StaticResource ColorBackground}"/>
    <SolidColorBrush x:Key="BrushSurface"          Color="{StaticResource ColorSurface}"/>
    <SolidColorBrush x:Key="BrushSurfaceElevated"  Color="{StaticResource ColorSurfaceElevated}"/>
    <SolidColorBrush x:Key="BrushSurfaceHover"     Color="{StaticResource ColorSurfaceHover}"/>
    <SolidColorBrush x:Key="BrushBorder"           Color="{StaticResource ColorBorder}"/>
    <SolidColorBrush x:Key="BrushBorderSubtle"     Color="{StaticResource ColorBorderSubtle}"/>

    <SolidColorBrush x:Key="BrushTextPrimary"      Color="{StaticResource ColorTextPrimary}"/>
    <SolidColorBrush x:Key="BrushTextSecondary"    Color="{StaticResource ColorTextSecondary}"/>
    <SolidColorBrush x:Key="BrushTextMuted"        Color="{StaticResource ColorTextMuted}"/>
    <SolidColorBrush x:Key="BrushTextAccent"       Color="{StaticResource ColorTextAccent}"/>

    <SolidColorBrush x:Key="BrushAccent"           Color="{StaticResource ColorAccent}"/>
    <SolidColorBrush x:Key="BrushAccentHover"      Color="{StaticResource ColorAccentHover}"/>
    <SolidColorBrush x:Key="BrushDanger"           Color="{StaticResource ColorDanger}"/>
    <SolidColorBrush x:Key="BrushSuccess"          Color="{StaticResource ColorSuccess}"/>

    <SolidColorBrush x:Key="BrushStatusRunning"    Color="{StaticResource ColorStatusRunning}"/>
    <SolidColorBrush x:Key="BrushStatusDegraded"   Color="{StaticResource ColorStatusDegraded}"/>
    <SolidColorBrush x:Key="BrushStatusFaulted"    Color="{StaticResource ColorStatusFaulted}"/>
    <SolidColorBrush x:Key="BrushStatusStopped"    Color="{StaticResource ColorStatusStopped}"/>
    <SolidColorBrush x:Key="BrushStatusStarting"   Color="{StaticResource ColorStatusStarting}"/>
    <SolidColorBrush x:Key="BrushStatusUnknown"    Color="{StaticResource ColorStatusUnknown}"/>

</ResourceDictionary>
